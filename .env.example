APP_ENV=local
LOG_LEVEL=INFO

GROQ_API_KEY=
GROQ_EXTRACTION_MODEL=llama-3.1-8b-instant
GROQ_PLANNER_MODEL=llama-3.3-70b-versatile
GROQ_INTERVIEW_MODEL=llama-3.3-70b-versatile
GROQ_EVALUATION_MODEL=llama-3.3-70b-versatile

VOICE_RECORD_SECONDS=5
VOICE_MAX_RECORD_SECONDS=45
VOICE_SILENCE_SECONDS=1.4
VOICE_VAD_THRESHOLD=0.015
VOICE_SAMPLE_RATE=16000
VOICE_TTS_VOICE=en-US-JennyNeural

WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en
